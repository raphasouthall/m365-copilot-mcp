# Copy to .env and fill in. Loaded by server.js (no dotenv dep; export these or use a wrapper).

# Bearer token Claude Code must present. Generate one: openssl rand -hex 32
MCP_AUTH_TOKEN=change-me

# Where the MCP HTTP endpoint binds. Bind to your tailnet/VPN IP so only that network can reach
# it (the client connects to this address). 127.0.0.1 keeps it on-box only.
MCP_BIND_ADDR=127.0.0.1
MCP_PORT=7800

# Localhost-only WebSocket bridge the Edge extension connects to. Never expose this off-box.
BRIDGE_BIND_ADDR=127.0.0.1
BRIDGE_PORT=8765

# Default Copilot surface when the caller doesn't specify one.
#   work  -> m365.cloud.microsoft/chat   (enterprise grounding; needs Copilot entitlement)
#   m365  -> copilot.cloud.microsoft      (M365 Copilot Chat)
#   web   -> copilot.microsoft.com        (consumer, web grounding only)
DEFAULT_SURFACE=work

# How long to wait for a single Copilot answer before giving up (ms).
ASK_TIMEOUT_MS=120000
